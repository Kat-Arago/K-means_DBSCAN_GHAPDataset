# Basic filters
df = df[df["PM25"].notna() & (df["PM25"] >= 0) & (df["PM25"] < 500)]
df = df[df["latitude"].notna() & df["longitude"].notna()]

# IQR outlier removal
q1, q3 = df["PM25"].quantile(0.25), df["PM25"].quantile(0.75)
iqr = q3 - q1
lo, hi = q1 - 2.5 * iqr, q3 + 2.5 * iqr
df = df[(df["PM25"] >= lo) & (df["PM25"] <= hi)]
print(f"IQR bounds [{lo:.2f}, {hi:.2f}]: {len(df):,} records retained")

df["latitude"]  = df["latitude"].round(2)
df["longitude"] = df["longitude"].round(2)

# Pivot: group by lat/lon, one column per month
df_pivot = (df.groupby(["latitude", "longitude", "Month"])["PM25"]
              .mean()
              .unstack("Month")
              .reset_index())

# Rename month columns
