def process_nc_file(file_path: str) -> pd.DataFrame:
    """Read one NetCDF file, sub-sample, return a DataFrame."""
    import xarray as xr
    records = []
    try:
        ds       = xr.open_dataset(file_path, engine="netcdf4")
        basename = os.path.basename(file_path)
        month    = basename.split("_")[3][:6]

        pm25_var = next(
            (v for v in ("PM2.5", "PM25", "pm2_5", "pm25") if v in ds.data_vars), None)
        if pm25_var is None:
            ds.close(); return pd.DataFrame()

        lat_name = next((d for d in ds.dims if d.lower() in ("lat","latitude")), None)
        lon_name = next((d for d in ds.dims if d.lower() in ("lon","longitude")), None)
        if lat_name is None or lon_name is None:
            ds.close(); return pd.DataFrame()

        ds_sub   = ds.isel({lat_name: slice(None, None, NC_STRIDE),
                             lon_name: slice(None, None, NC_STRIDE)})
        lat_vals = ds_sub[lat_name].values.astype(float)
        lon_vals = ds_sub[lon_name].values.astype(float)
        pm25_arr = ds_sub[pm25_var].values
        if pm25_arr.ndim == 3:
            pm25_arr = pm25_arr[0]
        elif pm25_arr.ndim != 2:
            ds.close(); return pd.DataFrame()

        lat_grid, lon_grid = np.meshgrid(lat_vals, lon_vals, indexing="ij")
        mask  = (pm25_arr >= 0) & (pm25_arr < 500) & ~np.isnan(pm25_arr)
        df_nc = pd.DataFrame({
            "latitude":  lat_grid[mask],
            "longitude": lon_grid[mask],
            "PM25":      pm25_arr[mask],
            "Month":     month,
        })
        ds.close()
        print(f"  [✓] {basename}: {len(df_nc):,} records")
        return df_nc
    except Exception as exc:
        print(f"  [!] Error {file_path}: {exc}")
        return pd.DataFrame()


