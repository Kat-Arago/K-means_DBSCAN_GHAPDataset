def compute_metrics(X, labels, name):
    mask = labels != -1
    Xm, ym = X[mask], labels[mask]
    nc = len(set(ym))
    if nc < 2:
        return {"algorithm":name,"silhouette":None,"davies_bouldin":None,
                "calinski_harabasz":None,"n_clusters":nc,
                "noise_points":int((labels==-1).sum())}
    sil = silhouette_score(Xm, ym, sample_size=min(5000, len(Xm)))
    db  = davies_bouldin_score(Xm, ym)
    ch  = calinski_harabasz_score(Xm, ym)
    print(f"  [{name}] Sil={sil:.4f}  DB={db:.4f}  CH={ch:.2f}  Clusters={nc}")
    return {"algorithm":name,"silhouette":round(sil,4),"davies_bouldin":round(db,4),
            "calinski_harabasz":round(ch,2),"n_clusters":nc,
            "noise_points":int((labels==-1).sum())}

km_metrics = compute_metrics(X_eval, merged.iloc[idx_m]["cluster"].values, "K-Means")
db_metrics = compute_metrics(X_eval, merged.iloc[idx_m]["dbscan_cluster"].values, "DBSCAN")
