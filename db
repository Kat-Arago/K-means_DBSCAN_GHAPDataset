# k-distance plot
nbrs = NearestNeighbors(n_neighbors=10, algorithm="ball_tree", n_jobs=-1).fit(X_sample)
dists, _ = nbrs.kneighbors(X_sample)
k_dists  = np.sort(dists[:, -1])[::-1]

fig, ax = plt.subplots(figsize=(10,4))
ax.plot(k_dists, color="#1D3557", lw=1)
ax.set(xlabel="Points (sorted)", ylabel="10-NN Distance", title="k-Distance Plot — eps guide")
ax.grid(alpha=0.3); plt.tight_layout(); save_fig("14_kdistance_plot.png")

# Parameter sweep
print("\nDBSCAN sweep …")
sweep_results = []
for eps in EPS_VALUES:
    for ms in MIN_SAMPLES_VALUES:
        lbl  = DBSCAN(eps=eps, min_samples=ms, n_jobs=-1).fit_predict(X_sample)
        nc   = len(set(lbl)) - (1 if -1 in lbl else 0)
        nn   = int((lbl == -1).sum())
        np_  = round(100 * nn / len(lbl), 2)
        sil  = None
        if nc >= 2:
            mask = lbl != -1
            if mask.sum() > 1:
                sil = round(silhouette_score(X_sample[mask], lbl[mask],
                                             sample_size=5000), 4)
        sweep_results.append({"eps":eps,"min_samples":ms,"n_clusters":nc,
                               "n_noise":nn,"noise_pct":np_,"silhouette":sil})
        print(f"  eps={eps:.2f} ms={ms:3d} | clusters={nc} noise={np_:.1f}% sil={sil}")

sweep_df = pd.DataFrame(sweep_results)
sweep_df.to_csv(os.path.join(OUT_DIR,"dbscan_parameter_sweep.csv"), index=False)

valid = sweep_df[
    sweep_df["n_clusters"].between(2,20) &
    (sweep_df["noise_pct"] < 30) &
    sweep_df["silhouette"].notna()
]
best_row = (valid.sort_values("silhouette", ascending=False).iloc[0]
            if not valid.empty
            else sweep_df[sweep_df["n_clusters"] >= 2].sort_values("noise_pct").iloc[0])
best_eps         = float(best_row["eps"])
best_min_samples = int(best_row["min_samples"])
print(f"\nBest DBSCAN: eps={best_eps}, min_samples={best_min_samples}")

# Final DBSCAN fit
final_db      = DBSCAN(eps=best_eps, min_samples=best_min_samples, n_jobs=-1)
